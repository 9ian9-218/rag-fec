# Neo4j：本機執行腳本/IDE 請用 127.0.0.1（埠已映射時）；docker compose 的 rag 服務會強制改為 neo4j 主機名
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Milvus：本機腳本用 127.0.0.1；rag 容器內由 compose 覆寫為 milvus
MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=lightrag_chunks

# ---------- 預設：雲端 LLM（DeepSeek OpenAI 相容）----------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-flash
OPENAI_TEMPERATURE=0.2

# 可選：本機 Ollama / vLLM（未設 OPENAI_MODEL 時才用 LLM_MODEL_NAME）
LLM_API_KEY=
LLM_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL_NAME=qwen2.5
LLM_TEMPERATURE=0.2

# ---------- 嵌入：本機 sentence-transformers（BAAI/bge-m3）----------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_ASYNC=2
EMBEDDING_LIGHTRAG_EMBEDDING_TIMEOUT=300

# 分塊
CHUNK_CHUNK_SIZE=1200
CHUNK_CHUNK_OVERLAP=100

# 檢索
RETRIEVAL_DEFAULT_MODE=mix
RETRIEVAL_TOP_K=10
RETRIEVAL_MAX_HOP=2
RETRIEVAL_ENABLE_BM25=true

# 增量
INCREMENTAL_ENABLED=true
INCREMENTAL_HASH_CACHE_PATH=data/hash_cache.json
INCREMENTAL_CHECKPOINT_INTERVAL=1
INCREMENTAL_CHECKPOINT_PATH=data/processed/incremental_checkpoint.json

# 服務
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_DEBUG=false
SERVICE_CORS_ORIGINS=*

# 路徑（容器內工作目錄通常為 /app）
PATHS_PROJECT_ROOT=.
PATHS_DATA_RAW=data/raw
PATHS_LIGHTRAG_WORKING_DIR=data/lightrag_workdir
PATHS_SQLITE_PATH=data/meta/app_kv.sqlite3

# LightRAG workspace（可留空）
WORKSPACE=

# LightRAG 摘要語言（與 FEC_SUMMARY_LANGUAGE 二選一或並用；未設時由程式設 Chinese）
SUMMARY_LANGUAGE=Chinese

# FEC 領域：實體類型（預設 12 類見 config/fec_defaults.py，與 rag-fec extraction 對齊）
FEC_SUMMARY_LANGUAGE=Chinese
# 可選：JSON 陣列字串覆寫類型，例如 ["coding_paradigm","table"]
# FEC_ENTITY_TYPES_JSON=

# 進階：若直接設定 ENTITY_TYPES（JSON 陣列），優先於 FEC 預設（apply_settings_to_environ 不覆寫已存在值）
# ENTITY_TYPES=["coding_paradigm","coding_scheme"]
