# Neo4j：本機執行腳本/API 時使用 127.0.0.1（與 docker compose 埠映射一致）
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# Milvus：本機腳本/API 使用 127.0.0.1（compose 已映射 19530）
MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=default
MILVUS_COLLECTION_NAME=lightrag_chunks
# pymilvus gRPC 連線就緒超時（秒）；LightRAG 未傳 timeout，專案會在建立實例前注入
MILVUS_CLIENT_TIMEOUT=120

# 多模態回答（--multimodal / API multimodal:true；與下方 OPENAI_* 分離）
# MULTIMODAL_API_KEY=none
# MULTIMODAL_BASE_URL=http://127.0.0.1:8080/v1
# MULTIMODAL_MODEL_NAME=Qwen3.5-9B
# MULTIMODAL_TEMPERATURE=0.2
# MULTIMODAL_MAX_IMAGES_PER_QUERY=3
# MULTIMODAL_REFERENCE_CONTEXT_MAX_CHARS=28000
# MULTIMODAL_MAX_IMAGE_BYTES=4000000

# ---------- 預設：雲端 LLM（DeepSeek OpenAI 相容）----------
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro
OPENAI_TEMPERATURE=0.2


# ---------- 嵌入：本機 sentence-transformers（BAAI/bge-m3）----------
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=16
EMBEDDING_MAX_ASYNC=2
EMBEDDING_LIGHTRAG_EMBEDDING_TIMEOUT=300

# 分塊
CHUNK_CHUNK_SIZE=1200
CHUNK_CHUNK_OVERLAP=100

# 檢索
RETRIEVAL_DEFAULT_MODE=mix
# 檢索前 LLM 自動選 naive/local/global/hybrid/mix（需 OPENAI_*）
RETRIEVAL_LLM_MODE_ROUTER_ENABLED=true
RETRIEVAL_LLM_MODE_ROUTER_TEMPERATURE=0
RETRIEVAL_TOP_K=8
RETRIEVAL_MAX_HOP=2
RETRIEVAL_ENABLE_BM25=true
# Rerank 歸一化分數低於此值的 chunk 過濾（提高可提升 context precision）
RETRIEVAL_RERANK_MIN_SCORE=0.35

# LightRAG 運行期（延遲 / 圖譜 / 關係檢索）
LIGHTRAG_MAX_ENTITY_TOKENS=8000
LIGHTRAG_MAX_RELATION_TOKENS=10000
LIGHTRAG_MAX_TOTAL_TOKENS=16000
LIGHTRAG_RELATED_ENTITY_CHUNK_NUMBER=5
LIGHTRAG_RELATED_RELATION_CHUNK_NUMBER=3
LIGHTRAG_RELATION_TOP_K=6
LIGHTRAG_RELATION_RERANK_ENABLED=true
LIGHTRAG_RELATION_MIN_RERANK_SCORE=0.4
LIGHTRAG_RELATION_KEYWORD_MIN_SCORE=0.15
LIGHTRAG_KG_CHUNK_PICK_METHOD=VECTOR
LIGHTRAG_MAX_GRAPH_NODES=128
LIGHTRAG_CHUNK_TOP_K=8
LIGHTRAG_COSINE_BETTER_THAN_THRESHOLD=0.25
LIGHTRAG_KEYWORD_FALLBACK_ENABLED=true
LIGHTRAG_ENTITY_EXTRACT_MAX_GLEANING=2

# 回答階段參考上下文字數上限（原 28000，下調可降延遲與 token）
MULTIMODAL_REFERENCE_CONTEXT_MAX_CHARS=12000

# 增量
INCREMENTAL_ENABLED=true
INCREMENTAL_HASH_CACHE_PATH=data/hash_cache.json
INCREMENTAL_CHECKPOINT_INTERVAL=1
INCREMENTAL_CHECKPOINT_PATH=data/processed/incremental_checkpoint.json

# 服務
SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000
SERVICE_DEBUG=false
SERVICE_CORS_ORIGINS=*

# 路徑（本機執行時相對專案根目錄）
PATHS_PROJECT_ROOT=.
PATHS_DATA_RAW=data/raw
PATHS_DATA_PROCESSED=data/processed
PATHS_LIGHTRAG_WORKING_DIR=data/lightrag_workdir
PATHS_SQLITE_PATH=data/meta/app_kv.sqlite3
# PATHS_DOCUMENT_MANIFEST_PATH=data/meta/document_manifest.json

# ---------- 本機模型（統一在專案 models/，Hub 快照在 models/hub/）----------
MODELS_DIR=models
MODELS_HF_ENDPOINT=https://hf-mirror.com
# MinerU 子進程會暫時取消 HF_ENDPOINT（鏡像常缺 commit 元數據），仍使用本專案 HF_HUB_CACHE；嵌入等可走鏡像。
MODELS_OFFLINE=true
# MODELS_EMBEDDING_LOCAL_PATH=

# Rerank（本機 CrossEncoder，預設 BAAI/bge-reranker-v2-m3，權重寫入 models/hub）
# MODELS_RERANK_ENABLED=true
# MODELS_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
# MODELS_RERANK_LOCAL_PATH=
# MODELS_RERANK_BATCH_SIZE=8
# 下載：python scripts/download_reranker.py（需可連 Hub；完成後可 MODELS_OFFLINE=true）

# 文件管線：two_stage（預設）= 先轉檔再索引；coupled = 入庫時內聯 MinerU/抽取
# DOCUMENT_PIPELINE_MODE=two_stage
# DOCUMENT_CONVERSION_CACHE_PATH=data/conversion_cache.json
# DOCUMENT_USE_MINERU_FOR_PDF=true
# DOCUMENT_MINERU_INFER_BACKEND=vlm-auto-engine
# DOCUMENT_MINERU_FORCE_REFRESH=false
#
# 推薦流程：
#   python scripts/convert.py incremental       # 僅 PDF→MD+images（轉檔增量）
#   python scripts/convert.py one data/raw/x.pdf  # 單個 PDF
#   python scripts/incremental_update.py          # 僅從 .md 等建 LightRAG 索引
#   python scripts/incremental_update.py --convert-first   # 兩步合併執行


# LightRAG workspace（可留空）
WORKSPACE=

# LightRAG 摘要語言（與 FEC_SUMMARY_LANGUAGE 二選一或並用；未設時由程式設 Chinese）
SUMMARY_LANGUAGE=Chinese

# FEC 領域：實體類型（預設 12 類見 config/fec_defaults.py，與 rag-fec extraction 對齊）
FEC_SUMMARY_LANGUAGE=Chinese
# 可選：JSON 陣列字串覆寫類型，例如 ["coding_paradigm","table"]
# FEC_ENTITY_TYPES_JSON=

# 進階：若直接設定 ENTITY_TYPES（JSON 陣列），優先於 FEC 預設（apply_settings_to_environ 不覆寫已存在值）
# ENTITY_TYPES=["coding_paradigm","coding_scheme"]
