# 快速配置示例
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填写你的 API Key
# 3. 根据需要选择启用 Embedding 和 Rerank API

# ==========================================
# 基础服务配置（Neo4j, Milvus, LLM）
# ==========================================
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=default

# LLM 配置(路由+回答)

OPENAI_API_KEY=
OPENAI_API_BASE=
OPENAI_MODEL=

# ==========================================
# Embedding API 配置
# ==========================================

# 【选项 1】使用 SiliconFlow
EMBEDDING_API_ENABLED=true
EMBEDDING_API_KEY=
EMBEDDING_API_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_API_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_API_TIMEOUT=60

# 【选项 2】使用本地模型（取消注释以禁用 API）
# EMBEDDING_API_ENABLED=false
# EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_DIMENSION=1024


# ==========================================
# Rerank API 配置
# ==========================================

# 【选项 1】使用 SiliconFlow Rerank
MODELS_RERANK_API_ENABLED=true
MODELS_RERANK_API_KEY=
MODELS_RERANK_API_BASE_URL=https://api.siliconflow.cn/v1
MODELS_RERANK_API_MODEL_NAME=BAAI/bge-reranker-v2-m3
MODELS_RERANK_API_TIMEOUT=60

# 【选项 2】使用本地 CrossEncoder（取消注释以禁用 API）
# MODELS_RERANK_API_ENABLED=false
# MODELS_RERANK_ENABLED=true
# MODELS_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3

# ==========================================
# 检索配置
# ==========================================
RETRIEVAL_DEFAULT_MODE=mix
RETRIEVAL_TOP_K=8
RETRIEVAL_RERANK_MIN_SCORE=0.35

# ==========================================
# 其他配置（保持默认即可）
# ==========================================
CHUNK_CHUNK_SIZE=1200
CHUNK_CHUNK_OVERLAP=100

SERVICE_HOST=0.0.0.0
SERVICE_PORT=8000

PATHS_PROJECT_ROOT=.
PATHS_LIGHTRAG_WORKING_DIR=data/lightrag_workdir
